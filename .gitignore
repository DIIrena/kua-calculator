# Next.js
node_modules/
.next/
next-env.d.ts
out/
*.tsbuildinfo

# Environment - never commit real keys
.env
.env*.local

# Editor / OS
.DS_Store

# Build artifacts
dist/
build/

# Local sample renders for owner review - regenerate via
# /api/dev/sample-compass; never commit the binaries.
samples/

# Python (retired Flask app - kept so any leftover venv is ignored)
.venv/
__pycache__/
*.pyc
*.egg-info/

# Visual production - heavy binaries stay local (like the pin masters).
# Keep tracked: prompts/, manifests/*.json, *.md review sheets, README.md
visual-production/drafts/
visual-production/approved/
visual-production/contact-sheets/**/*.png
visual-production/contact-sheets/**/*.jpg
visual-production/contact-sheets/**/*.mp4
visual-production/contact-sheets/**/*.webm

# Visual production local dashboard - app source is tracked; ignore local cache/logs.
# (node_modules is already covered by the global rule above; listed for clarity.)
visual-production/dashboard-app/node_modules/
visual-production/dashboard-app/.cache/
visual-production/dashboard-app/*.log
