# My Feng Shui Home - Kua Calculator - environment variables
#
# Copy this file to .env.local and fill in real values. On Vercel, set
# the same variables in Project Settings -> Environment Variables for
# Preview and Production.
#
# Auth runs on the Next.js server via Auth.js v5 (NextAuth). Supabase is
# the database only. The calculator, methodology, and embed pages work
# fully with placeholders; only sign-in / account need real keys.

# ---------- Auth.js (NextAuth) ----------

# Session-cookie signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# or `openssl rand -base64 32`. Required in production.
AUTH_SECRET=

# Google OAuth client. Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth 2.0 Client IDs. The authorised redirect URI is
# https://myfengshuihome.com/api/auth/callback/google (and the local
# equivalent http://localhost:3000/api/auth/callback/google).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend API key, used for the magic-link sign-in email. Resend
# dashboard -> API Keys. Verify the sending domain first.
AUTH_RESEND_KEY=

# ---------- Supabase (database only) ----------

# Supabase project URL. Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service-role key. Bypasses Row-Level Security. SERVER ONLY -
# never expose this to the browser. Used by the Auth.js Supabase adapter
# and by every server-side DB read/write.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Site ----------

# The canonical site URL. Local: http://localhost:3000
# Production: https://myfengshuihome.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Analytics ----------

# Plausible Analytics domain. Cookie-free pageview + custom-event tracker.
# Set to the canonical domain (no scheme) you configured in Plausible
# dashboard, e.g. "myfengshuihome.com". Marketing surfaces only:
# /kua-calculator and /embed stay tracker-free even when this is set.
# Leave unset locally to disable analytics entirely (no script loads, no
# events fire).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
