# My Feng Shui Home - Kua Calculator - environment variables
#
# Copy this file to .env.local and fill in real values. On Vercel, set
# the same variables in Project Settings -> Environment Variables for
# Preview and Production.
#
# Auth runs on the Next.js server via Auth.js v5 (NextAuth). Supabase is
# the database only. The calculator, methodology, and embed pages work
# fully with placeholders; only sign-in / account need real keys.

# ---------- Auth.js (NextAuth) ----------

# Session-cookie signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# or `openssl rand -base64 32`. Required in production.
AUTH_SECRET=

# Google OAuth client. Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth 2.0 Client IDs. The authorised redirect URI is
# https://myfengshuihome.com/api/auth/callback/google (and the local
# equivalent http://localhost:3000/api/auth/callback/google).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend API key, used for the magic-link sign-in email. Resend
# dashboard -> API Keys. Verify the sending domain first.
AUTH_RESEND_KEY=

# ---------- Supabase (database only) ----------

# Supabase project URL. Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service-role key. Bypasses Row-Level Security. SERVER ONLY -
# never expose this to the browser. Used by the Auth.js Supabase adapter
# and by every server-side DB read/write.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Site ----------

# The canonical site URL. Local: http://localhost:3000
# Production: https://myfengshuihome.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Stripe (the buy flow) ----------

# Secret key: sk_test_... for preview/test, sk_live_... in production.
# Stripe dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=

# Publishable key (pk_test_... / pk_live_...). Not currently read by
# the code (Checkout is hosted by Stripe) but kept alongside for
# completeness and any future embedded elements.
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret for /api/stripe-webhook. Stripe dashboard ->
# Developers -> Webhooks -> the endpoint -> Signing secret (whsec_...).
STRIPE_WEBHOOK_SECRET=

# One Price ID env var per buyable product (lib/commerce.ts maps the
# product slug to the env key). Test and live modes carry different
# Price IDs; set per environment in Vercel.
STRIPE_PRICE_PLANNER=
STRIPE_PRICE_COMPASS=
STRIPE_PRICE_CALENDAR=

# ---------- Analytics ----------

# No analytics env var is required. Pageviews are handled by Vercel Web
# Analytics through the @vercel/analytics package mounted in
# app/(site)/layout.tsx. Vercel wires the tracker up automatically once
# Web Analytics is enabled in the project dashboard. Local dev sends no
# events because /_vercel/insights is not reachable outside a Vercel
# deployment. Custom funnel events are deferred (lib/analytics.ts is a
# no-op) until we move to a paid tier.
